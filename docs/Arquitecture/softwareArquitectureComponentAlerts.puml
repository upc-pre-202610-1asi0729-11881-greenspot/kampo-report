@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_TOP_DOWN()
HIDE_STEREOTYPE()

title Component Diagram – Alert Management Bounded Context

Container_Ext(spa, "Web Application", "Angular", "Calls alert management endpoints")
Container_Ext(monitoringBC, "Monitoring IoT BC", "Internal", "Publishes ReadingRegistered events")
Container_Ext(fieldOpBC, "Field Operation BC", "Internal", "Publishes VisitCompleted and ObservationRegistered events")
ContainerDb_Ext(db, "Database", "MySQL", "Persistent storage")

Container_Boundary(alertBC, "Alert Management – Bounded Context") {

    Boundary(interfaces, "interfaces/rest", "REST Controllers & Event Consumers") {
        Component(ruleController,  "AlertRuleController",  "REST Controller", "Handles /rules endpoints: create, configure, list")
        Component(alertController, "AlertController",      "REST Controller", "Handles /alerts endpoints: list, mark as read")
        Component(eventConsumer,   "AlertEventConsumer",   "Event Consumer",  "Listens to ReadingRegistered and ObservationRegistered events")
        Component(notificationPub, "NotificationPublisher","Event Publisher", "Publishes AlertSent event to notification service")
    }

    Boundary(application, "application", "Use Cases / Application Services") {
        Component(createRuleUC,   "CreateAlertRuleUseCase",    "Application Service", "Validates and persists a new alert rule with its conditions")
        Component(configureRuleUC,"ConfigureAlertRuleUseCase", "Application Service", "Updates thresholds and conditions of an existing rule")
        Component(evaluateCondUC, "EvaluateConditionUseCase",  "Application Service", "Evaluates incoming event data against active rules")
        Component(sendAlertUC,    "SendAlertUseCase",          "Application Service", "Creates and dispatches alert when condition is met")
        Component(markReadUC,     "MarkAlertAsReadUseCase",    "Application Service", "Marks a dispatched alert as read by the user")
    }

    Boundary(domain, "domain/model", "Domain Services & Aggregates") {
        Component(ruleDomainSvc,  "AlertRuleDomainService", "Domain Service", "Condition matching logic and rule activation")
        Component(alertDomainSvc, "AlertDomainService",     "Domain Service", "Alert severity, deduplication and cooldown")
    }

    Boundary(infrastructure, "infrastructure/persistence/jpa", "Repositories") {
        Component(ruleRepo,      "AlertRuleRepository", "Repository", "CRUD for AlertRule aggregate")
        Component(conditionRepo, "ConditionRepository", "Repository", "CRUD for Condition value objects within rules")
        Component(alertRepo,     "AlertRepository",     "Repository", "CRUD for Alert aggregate")
    }
}

' === External → Interface ===
Rel(spa,          ruleController,  "GET|POST|PUT /rules",         "HTTPS/JSON")
Rel(spa,          alertController, "GET|PUT /alerts",             "HTTPS/JSON")
Rel(monitoringBC, eventConsumer,   "ReadingRegistered event",     "Internal")
Rel(fieldOpBC,    eventConsumer,   "ObservationRegistered event", "Internal")

' === Interface → Application ===
Rel(ruleController,  createRuleUC,   "Calls")
Rel(ruleController,  configureRuleUC,"Calls")
Rel(alertController, markReadUC,     "Calls")
Rel(eventConsumer,   evaluateCondUC, "Triggers evaluation")

' === Application → Domain ===
Rel(createRuleUC,    ruleDomainSvc,  "Validates rule structure")
Rel(configureRuleUC, ruleDomainSvc,  "Validates updated thresholds")
Rel(evaluateCondUC,  ruleDomainSvc,  "Matches event data against rules")
Rel(sendAlertUC,     alertDomainSvc, "Applies deduplication and severity")
Rel(markReadUC,      alertDomainSvc, "Validates alert belongs to user")

' === Application → Infrastructure ===
Rel(createRuleUC,    ruleRepo,       "Persists rule")
Rel(createRuleUC,    conditionRepo,  "Persists conditions")
Rel(configureRuleUC, ruleRepo,       "Updates rule")
Rel(configureRuleUC, conditionRepo,  "Updates conditions")
Rel(evaluateCondUC,  ruleRepo,       "Queries active rules")
Rel(evaluateCondUC,  conditionRepo,  "Queries conditions")
Rel(evaluateCondUC,  sendAlertUC,    "Calls if condition met")
Rel(sendAlertUC,     alertRepo,      "Persists alert")
Rel(sendAlertUC,     notificationPub,"Publishes AlertSent event")
Rel(markReadUC,      alertRepo,      "Updates alert status")

' === Infrastructure → DB ===
Rel(ruleRepo,      db, "Reads/Writes", "JDBC")
Rel(conditionRepo, db, "Reads/Writes", "JDBC")
Rel(alertRepo,     db, "Reads/Writes", "JDBC")

@enduml