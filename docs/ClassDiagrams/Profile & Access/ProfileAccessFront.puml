@startuml

left to right direction

title Class Diagram - Profile & Access (Frontend)

package "application" {
  class ProfileAccessStore <<Store>> {
    -currentUser: User
    -roles: Role[]
    -permissions: Permission[]
    -isLoading: boolean

    +registerUser(user: User): void
    +login(email: string, password: string): void
    +modifyProfile(user: User): void
    +assignRole(userId: number, roleId: number): void
    +assignPermission(roleId: number, permissionId: number): void
    +getCurrentUser(): User
    +getRoles(): Role[]
    +getPermissions(): Permission[]
  }
}

package "presentation" {
  package "views" {
    class RegistrationFormComponent <<Component>> {
      -user: User
      -isLoading: boolean

      +ngOnInit(): void
      +onRegisterUser(): void
    }

    class LoginFormComponent <<Component>> {
      -email: string
      -password: string
      -isLoading: boolean

      +ngOnInit(): void
      +onLogin(): void
    }

    class ProfileViewComponent <<Component>> {
      -currentUser: User
      -isLoading: boolean

      +ngOnInit(): void
      +onModifyProfile(): void
    }

    class RoleAssignmentComponent <<Component>> {
      -users: User[]
      -roles: Role[]

      +ngOnInit(): void
      +onAssignRole(userId: number, roleId: number): void
    }

    class PermissionAssignmentComponent <<Component>> {
      -roles: Role[]
      -permissions: Permission[]

      +ngOnInit(): void
      +onAssignPermission(roleId: number, permissionId: number): void
    }
  }
}

package "infrastructure" {
  class ProfileAccessApi {
    -registerEndpoint: string
    -loginEndpoint: string
    -profileEndpoint: string
    -roleEndpoint: string
    -permissionEndpoint: string

    +registerUser(user: User): Observable<User>
    +login(email: string, password: string): Observable<User>
    +modifyProfile(user: User): Observable<User>
    +assignRole(userId: number, roleId: number): Observable<Role>
    +assignPermission(roleId: number, permissionId: number): Observable<Permission>
  }

  class UserAssembler {
    +toEntityFromResponse(response: UserResponse): User
    +toResourceFromEntity(entity: User): UserResource
  }

  class RoleAssembler {
    +toEntityFromResponse(response: RoleResponse): Role
    +toResourceFromEntity(entity: Role): RoleResource
  }

  class PermissionAssembler {
    +toEntityFromResponse(response: PermissionResponse): Permission
    +toResourceFromEntity(entity: Permission): PermissionResource
  }

  class UserResponse {
    -id: number
    -name: string
    -email: string
    -roleId: number
  }

  class RoleResponse {
    -id: number
    -name: string
  }

  class PermissionResponse {
    -id: number
    -name: string
  }

  class UserResource {
    -id: number
    -name: string
    -email: string
    -roleId: number
  }

  class RoleResource {
    -id: number
    -name: string
  }

  class PermissionResource {
    -id: number
    -name: string
  }
}

package "domain" {
  package "model" {
    package "entities" {
      class User <<Entity>> {
        -id: number
        -name: string
        -email: string
        -roleId: number

        +getId(): number
        +getName(): string
        +getEmail(): string
        +getRoleId(): number
        +setName(name: string): void
        +setEmail(email: string): void
      }

      class Role <<Entity>> {
        -id: number
        -name: string

        +getId(): number
        +getName(): string
      }

      class Permission <<Entity>> {
        -id: number
        -name: string

        +getId(): number
        +getName(): string
      }
    }
  }
}

ProfileAccessStore -down-> ProfileAccessApi : delegates to
ProfileAccessStore -right-> User
ProfileAccessStore -right-> Role
ProfileAccessStore -right-> Permission

ProfileAccessApi ..down..> UserAssembler : uses for conversion
ProfileAccessApi ..down..> RoleAssembler : uses for conversion
ProfileAccessApi ..down..> PermissionAssembler : uses for conversion

UserAssembler ..right..> UserResponse
UserAssembler ..right..> UserResource
UserAssembler ..right..> User

RoleAssembler ..right..> RoleResponse
RoleAssembler ..right..> RoleResource
RoleAssembler ..right..> Role

PermissionAssembler ..right..> PermissionResponse
PermissionAssembler ..right..> PermissionResource
PermissionAssembler ..right..> Permission

RegistrationFormComponent ..down..> ProfileAccessStore : uses
LoginFormComponent ..down..> ProfileAccessStore : uses
ProfileViewComponent ..down..> ProfileAccessStore : uses
RoleAssignmentComponent ..down..> ProfileAccessStore : uses
PermissionAssignmentComponent ..down..> ProfileAccessStore : uses

User --> Role
Role --> Permission
@enduml